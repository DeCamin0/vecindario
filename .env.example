# Copiază la .env și completează (nu comita .env).
#
# Vecindario folosește DOAR baza vecindario_db — nu decamino_db / hera_facility_db.
# Pe MySQL: CREATE DATABASE IF NOT EXISTS vecindario_db CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
#
# Prisma citește DATABASE_URL. În URL, caracterele speciale din parolă trebuie encodate (ex. ! → %21).
#
# Exemplu (înlocuiește USER și PASSWORD):
# DATABASE_URL="mysql://USER:PASSWORD@217.154.102.115:3306/vecindario_db"
#
# Dacă îți place stilul DB_* (doar referință — aplicația folosește DATABASE_URL):
# DB_TYPE=mysql
# DB_HOST=217.154.102.115
# DB_PORT=3306
# DB_USERNAME=your_user
# DB_PASSWORD=your_password
# DB_NAME=vecindario_db

DATABASE_URL="mysql://user:password@127.0.0.1:3306/vecindario_db"

# Obligatoriu pentru API (server). Generează: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="schimba-cu-un-secret-lung-minim-16-caractere"
JWT_EXPIRES_IN=7d
PORT=4001
CORS_ORIGIN=http://localhost:5175,http://localhost:5173

# Cron diario (03:00 hora del servidor): comunidades active con plan_expires_on vencido → inactive.
# En desarrollo puedes poner 1 para no programar el cron.
# SUBSCRIPTION_CRON_DISABLED=1

# După migrări: npm run server:seed
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=schimba-parola
SUPER_ADMIN_NAME=Super Admin

# Correo al dar de alta comunidad (presidente/admin). Ej. serviciodecorreo.es:
# En producción usa https en APP_PUBLIC_URL para que el logo en correos cargue en Gmail (no uses solo data-URI).
# APP_PUBLIC_URL=https://tudominio.es/vecindario
# EMAIL_LOGO_URL=https://tudominio.es/vecindario/Vencindario_logo.png
# Dev con Mailhog y logo embebido: EMAIL_LOGO_DATA_URI=true
# APP_PUBLIC_URL=http://localhost:5173/vecindario
# SMTP_HOST=smtp.serviciodecorreo.es
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=vecindario@decamino.es
# SMTP_PASS=tu_contraseña
# SMTP_FROM=vecindario@decamino.es

# Opțional: dacă e gol, Vite face proxy /api → PORT (vezi vite.config.js)
# VITE_VECINDARIO_API_URL=http://localhost:4001
#
# URL público del sitio (sin barra final) para enlaces y QR de acceso por slug en Super Admin.
# En dev suele bastar vacío (usa window.location.origin). En producción: https://tudominio.es
# VITE_PUBLIC_APP_ORIGIN=https://tudominio.es
#
# Enlaces a tiendas de la app móvil (banner «Descargar app» y página /open-app).
# iOS: URL completa de App Store cuando la app esté publicada.
# Android: opcional; si está vacío se usa el package com.decamino.vecindario en Play.
# VITE_VECINDARIO_IOS_APP_STORE_URL=https://apps.apple.com/app/id123456789
# VITE_VECINDARIO_ANDROID_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.decamino.vecindario

# --- Web Push (notificări PWA în fundal) — opțional; fără ele, rămân WebSocket + Expo pe mobil ---
# Generează chei: cd server && npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@domeniu.ro
