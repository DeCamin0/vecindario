// Vecindario — exclusiv baza `vecindario_db` (DATABASE_URL în .env). Nu folosi decamino_db aici.

// Client implicit: vecindario-app/node_modules/.prisma (compatibil cu @prisma/client hoisted din rădăcină).
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum VecindarioRole {
  resident
  community_admin
  company_admin
  president
  super_admin
  concierge
  /// Socorrista / personal de acceso solo a validación de piscina
  pool_staff
}

/// Utilizatori Vecindario (login API). Tabel dedicat, separat de DeCamino.
model VecindarioUser {
  id           Int            @id @default(autoincrement())
  /// Opcional para vecinos dados de alta solo con portal + piso (sin correo).
  email        String?        @unique @db.VarChar(255)
  passwordHash String         @map("password_hash") @db.VarChar(255)
  /// Última contraseña en claro asignada por el sistema (alta / reset). No se actualiza si el usuario cambia la clave en la app.
  passwordPlainSnapshot String? @map("password_plain_snapshot") @db.VarChar(255)
  name         String?        @db.VarChar(255)
  /// Ruta pública de foto de perfil (ej. /api/uploads/avatars/12.jpg).
  profileImageUrl String?     @map("profile_image_url") @db.VarChar(512)
  /// Teléfono de contacto (opcional).
  phone        String?        @map("phone") @db.VarChar(40)
  /// Piso / planta u otro identificador de vivienda (texto libre).
  piso         String?        @map("piso") @db.VarChar(64)
  /// Portal o acceso de la finca (ej. 34, P1); columna aparte, no mezclar con piso.
  portal       String?        @map("portal") @db.VarChar(64)
  /// Puerta / apartamento (texto libre). Obligatorio en alta de vecino; puede ser null en cuentas antiguas.
  puerta       String?        @map("puerta") @db.VarChar(64)
  /// Habitaciones (dato informativo, texto libre).
  habitaciones String?        @map("habitaciones") @db.VarChar(64)
  /// Plaza de garaje (opcional, texto libre).
  plazaGaraje  String?        @map("plaza_garaje") @db.VarChar(64)
  /// Accesos piscina titular (texto / número como dato).
  poolAccessOwner String?     @map("pool_access_owner") @db.VarChar(64)
  /// Accesos piscina invitado (texto / número como dato).
  poolAccessGuest String?     @map("pool_access_guest") @db.VarChar(64)
  /// Comunidad del vecino (obligatoria si alta sin email; null en staff/presidente sin enlace).
  communityId  Int?           @map("community_id")
  community    Community?     @relation(fields: [communityId], references: [id], onDelete: SetNull)
  /// Empresa gestionada (solo rol company_admin).
  companyAdminCompanyId Int?    @map("company_admin_company_id")
  companyAdminCompany   Company? @relation("CompanyAdminUsers", fields: [companyAdminCompanyId], references: [id], onDelete: SetNull)
  role         VecindarioRole @default(resident)
  /// Preferencias: notificaciones Web Push (PWA).
  notifyWebPush    Boolean @default(true) @map("notify_web_push")
  /// Preferencias: notificaciones push en app móvil (Expo).
  notifyMobilePush Boolean @default(true) @map("notify_mobile_push")
  /// Preferencias: correos transaccionales a email de la cuenta.
  notifyEmail      Boolean @default(true) @map("notify_email")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  bookings                 CommunityBooking[]
  bookingsBookedOnBehalf   CommunityBooking[] @relation("BookingBookedBy")
  gymAccessLogs     CommunityGymAccessLog[]
  reportedIncidents   CommunityIncident[]         @relation("IncidentReporter")
  resolvedIncidents   CommunityIncident[]         @relation("IncidentResolver")
  incidentComments    CommunityIncidentComment[]  @relation("IncidentCommentAuthor")
  serviceRequestsRequested CommunityServiceRequest[] @relation("ServiceRequestRequester")
  serviceRequestMessages CommunityServiceRequestMessage[] @relation("ServiceRequestMessageAuthor")
  vecindarioNotifications    VecindarioNotification[]
  expoPushTokens             VecindarioExpoPushToken[]
  webPushSubscriptions       VecindarioWebPushSubscription[]
  poolAccessPasses           PoolAccessPass[]
  poolValidationsAsResident  PoolAccessValidationLog[] @relation("PoolValidationResident")
  poolValidationsAsValidator PoolAccessValidationLog[] @relation("PoolValidator")
  poolPresenceAsResident     PoolPresenceSession[]      @relation("PoolPresenceResident")
  poolPresenceAsValidator    PoolPresenceSession[]      @relation("PoolPresenceValidator")
  parcelsReceived            CommunityConciergeParcel[]  @relation("ParcelRecipient")
  parcelsCreated             CommunityConciergeParcel[]  @relation("ParcelCreatedBy")
  parcelsHandedOver          CommunityConciergeParcel[]  @relation("ParcelPickedUpBy")
  diarioEntriesCreated       CommunityDiarioEntry[]      @relation("DiarioCreatedBy")

  @@index([communityId], map: "vecindario_users_community_id_idx")
  @@index([companyAdminCompanyId], map: "vecindario_users_company_admin_company_idx")
  @@map("vecindario_users")
}

/// Empresa (administradores de empresa crean comunidades pendientes de aprobación).
model Company {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  communities        Community[]
  companyAdminUsers  VecindarioUser[] @relation("CompanyAdminUsers")

  @@map("companies")
}

/// Comunități (gestionate din Super Admin).
model Community {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(255)
  /// NIF / CIF (opcional en alta; se puede completar después).
  nifCif        String?  @map("nif_cif") @db.VarChar(32)
  /// Dirección de la finca / comunidad (opcional; facturación, correos, referencia).
  address       String?  @map("address") @db.VarChar(512)
  accessCode    String?  @unique @map("access_code") @db.VarChar(100)
  /// Slug para enlace corto de acceso: /c/{loginSlug}/login (opcional, único).
  loginSlug     String?  @unique @map("login_slug") @db.VarChar(80)
  /// Email principal comunidad (vecinos / avisos) — único obligatorio en alta desde Super Admin.
  contactEmail  String?  @map("contact_email") @db.VarChar(255)
  /// Email del presidente (legado: entrada correo + VEC). Opcional si el presidente es vecino por vivienda.
  presidentEmail String? @map("president_email") @db.VarChar(255)
  /// Portal de acceso de la vivienda del presidente actual (mismo criterio que vecinos; rotación anual).
  presidentPortal String? @map("president_portal") @db.VarChar(64)
  /// Piso del presidente actual.
  presidentPiso   String? @map("president_piso") @db.VarChar(64)
  /// Puerta / apartamento del presidente (distinto por vivienda en el mismo piso).
  presidentPuerta String? @map("president_puerta") @db.VarChar(64)
  /// Vivienda del vicepresidente de la junta (portal + piso + puerta).
  boardVicePortal String? @map("board_vice_portal") @db.VarChar(64)
  boardVicePiso   String? @map("board_vice_piso") @db.VarChar(64)
  boardVicePuerta String? @map("board_vice_puerta") @db.VarChar(64)
  /// Vocales: [{ "portal", "piso", "puerta"? }, …]
  boardVocalsJson Json?   @map("board_vocals_json")
  /// Email del administrador de comunidad (gestión incidencias/reservas; instrucciones de alta).
  communityAdminEmail String? @map("community_admin_email") @db.VarChar(255)
  /// Nombre del administrador o de la empresa de gestión (correos de alta, ficha de ayuda).
  communityAdminName  String? @map("community_admin_name") @db.VarChar(255)
  /// Email del conserje / portería (opcional; alta automática e invitación como en presidente/admin).
  conciergeEmail String? @map("concierge_email") @db.VarChar(255)
  /// Segundo conserje (legacy; espejo de [1] en conciergeEmailsJson).
  conciergeEmail2 String? @map("concierge_email_2") @db.VarChar(255)
  /// Hasta 5 conserjes: JSON array de correos (fuente principal).
  conciergeEmailsJson Json @default("[]") @map("concierge_emails_json")
  /// Conserje suplente / refuerzo (mismo rol; no cuenta en el límite de 5).
  conciergeSubstituteEmail String? @map("concierge_substitute_email") @db.VarChar(255)
  conciergeSubstituteName String? @map("concierge_substitute_name") @db.VarChar(255)
  /// Email del socorrista / validación de acceso a piscina (mismo criterio que conserje: ficha + VEC en login).
  poolStaffEmail String? @map("pool_staff_email") @db.VarChar(255)
  status        String   @default("active") @db.VarChar(32)
  /// Último día inclusivo del plan (null = sin caducidad). Tras esa fecha, el job diario pasa la comunidad a inactive.
  planExpiresOn DateTime? @map("plan_expires_on") @db.Date
  /// Número de portales / accesos (planificación).
  portalCount   Int      @default(1) @map("portal_count")
  /// Nombre o alias por portal (JSON: ["34","36",…]); índice 0 = portal 1; longitud acorde a portalCount.
  portalLabels  Json     @default("[]") @map("portal_labels")
  /// Por portal (misma longitud que portalCount): plantas, puertas por planta y letras vs números — ver portal-dwelling-config.ts.
  portalDwellingConfig Json @default("[]") @map("portal_dwelling_config")
  /// Cupo previsto de vecinos / cuentas (null = sin tope definido aún).
  residentSlots Int?     @map("resident_slots")
  /// Control de acceso al gimnasio (activar / desactivar; editable después).
  gymAccessEnabled Boolean @default(false) @map("gym_access_enabled")
  /// Cuántas pistas de pádel tiene la comunidad (0 = ninguna).
  padelCourtCount  Int     @default(0) @map("padel_court_count")
  /// Máximo de horas por una reserva de pádel (una franja cuenta como tal duración en la cuota diaria).
  padelMaxHoursPerBooking Int @default(2) @map("padel_max_hours_per_booking")
  /// Máximo total de horas de pádel por vivienda (piso) y día natural; mismo criterio por email si no hay piso.
  padelMaxHoursPerApartmentPerDay Int @default(4) @map("padel_max_hours_apartment_day")
  /// Horas mínimas de antelación respecto al inicio del tramo (ej. 24 = 1 día, 48 = 2 días).
  padelMinAdvanceHours Int @default(24) @map("padel_min_advance_hours")
  /// Inicio del horario reservable de pádel (HH:mm, hora local de la comunidad).
  padelOpenTime  String @default("08:00") @map("padel_open_time") @db.VarChar(5)
  /// Fin del horario reservable de pádel (HH:mm); debe ser posterior a padelOpenTime el mismo día.
  padelCloseTime String @default("22:00") @map("padel_close_time") @db.VarChar(5)
  /// Salones (sala reuniones, salón social, espacios custom): `slots` = franjas mañana/tarde/noche; `day` = reserva por día completo.
  salonBookingMode String @default("slots") @map("salon_booking_mode") @db.VarChar(32)
  /// Salones / espacios con nombre propio: [{ "id", "name" }, …]
  customLocations  Json    @default("[]") @map("custom_locations")
  /// App vecinos: mostrar pestaña Servicios (solicitudes).
  appNavServicesEnabled  Boolean @default(true) @map("app_nav_services_enabled")
  /// Por categoría (plumber, electrician, …): "active" o "soon" en JSON; {} = todas disponibles.
  serviceRequestCategoryModesJson Json @default("{}") @map("service_request_category_modes_json")
  /// App vecinos: pestaña Incidencias.
  appNavIncidentsEnabled Boolean @default(true) @map("app_nav_incidents_enabled")
  /// App vecinos: pestaña Reservas.
  appNavBookingsEnabled  Boolean @default(true) @map("app_nav_bookings_enabled")
  /// App vecinos: pestaña Acceso piscina (visible solo si está marcada).
  appNavPoolAccessEnabled Boolean @default(false) @map("app_nav_pool_access_enabled")
  /// App vecinos: pestaña Paquetería (conserjería: entrega/recogida de paquetes).
  appNavPaqueteriaEnabled Boolean @default(false) @map("app_nav_paqueteria_enabled")
  /// Cuaderno diario del conserje (junta y administración: solo lectura).
  appNavCuadernoDiarioEnabled Boolean @default(false) @map("app_nav_cuaderno_diario_enabled")
  /// Sistema de acceso a piscina (códigos / validación por socorrista).
  poolAccessSystemEnabled Boolean @default(false) @map("pool_access_system_enabled")
  /// Temporada de piscina activa (interruptor rápido).
  poolSeasonActive        Boolean @default(false) @map("pool_season_active")
  poolSeasonStart         DateTime? @map("pool_season_start") @db.Date
  poolSeasonEnd           DateTime? @map("pool_season_end") @db.Date
  /// Texto libre de horario (ej. 10:00–21:00); MVP sin reglas por franja.
  poolHoursNote           String?   @map("pool_hours_note") @db.VarChar(255)
  /// Tope de personas en la instalación a la vez (null = sin límite global; sigue el tope por vivienda al admitir).
  poolMaxOccupancy        Int?      @map("pool_max_occupancy")
  createdAt        DateTime @default(now()) @map("created_at")
  /// Empresa propietaria (opcional; comunidades legacy sin empresa).
  companyId        Int?     @map("company_id")
  company          Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  bookings         CommunityBooking[]
  gymAccessLogs    CommunityGymAccessLog[]
  vecindarioUsers  VecindarioUser[]
  incidents        CommunityIncident[]
  serviceRequests  CommunityServiceRequest[]
  poolAccessPasses PoolAccessPass[]
  poolAccessValidationLogs PoolAccessValidationLog[]
  poolPresenceSessions     PoolPresenceSession[]
  conciergeParcels         CommunityConciergeParcel[]
  diarioEntries            CommunityDiarioEntry[]

  @@index([companyId], map: "communities_company_id_idx")
  @@map("communities")
}

/// Entradas del cuaderno diario del conserje (hora + texto por día).
model CommunityDiarioEntry {
  id              Int            @id @default(autoincrement())
  communityId     Int            @map("community_id")
  community       Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  entryDate       DateTime       @map("entry_date") @db.Date
  /// Minutos desde medianoche (0–1439), hora local de la anotación.
  startMinute     Int            @map("start_minute")
  description     String         @db.Text
  createdByUserId Int            @map("created_by_user_id")
  createdBy       VecindarioUser @relation("DiarioCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  createdByName   String?        @map("created_by_name") @db.VarChar(255)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  @@index([communityId, entryDate, startMinute], map: "cdiario_comm_date_min_idx")
  @@index([createdByUserId], map: "cdiario_created_by_idx")
  @@map("community_diario_entries")
}

/// Paquetes en conserjería (registro por portal/piso/puerta; firma al recoger).
model CommunityConciergeParcel {
  id                Int            @id @default(autoincrement())
  communityId       Int            @map("community_id")
  community         Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  portal            String         @db.VarChar(64)
  piso              String         @db.VarChar(64)
  puerta            String         @db.VarChar(64)
  recipientUserId   Int            @map("recipient_user_id")
  recipient         VecindarioUser @relation("ParcelRecipient", fields: [recipientUserId], references: [id], onDelete: Restrict)
  createdByUserId   Int            @map("created_by_user_id")
  createdBy         VecindarioUser @relation("ParcelCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  /// Nombre del conserje/gestor al registrar el paquete (histórico).
  createdByName     String?        @map("created_by_name") @db.VarChar(255)
  /// Fotos del paquete: JSON array de data URLs (mismo criterio que incidencias; tamaño limitado en API).
  photosJson        Json           @default("[]") @map("photos_json")
  /// awaiting_pickup | picked_up
  status            String         @default("awaiting_pickup") @map("status") @db.VarChar(32)
  /// Número de bultos entregados en este registro (1–20 en API).
  packageCount      Int            @default(1) @map("package_count")
  /// Imagen de firma (data URL PNG) al marcar recogido.
  signatureImage    String?        @map("signature_image") @db.LongText
  pickedUpAt        DateTime?      @map("picked_up_at")
  /// Conserje/gestor que registró la entrega con firma al vecino.
  pickedUpByUserId  Int?           @map("picked_up_by_user_id")
  pickedUpBy        VecindarioUser? @relation("ParcelPickedUpBy", fields: [pickedUpByUserId], references: [id], onDelete: SetNull)
  pickedUpByName    String?        @map("picked_up_by_name") @db.VarChar(255)
  /// resident | concierge (quién confirmó la entrega con firma).
  pickedUpByRole    String?        @map("picked_up_by_role") @db.VarChar(24)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  @@index([communityId, status], map: "ccp_comm_status_idx")
  @@index([recipientUserId, status], map: "ccp_recipient_status_idx")
  @@map("community_concierge_parcels")
}

/// Código corto de acceso a piscina (vecino); caducidad típica 24h.
model PoolAccessPass {
  id          Int            @id @default(autoincrement())
  userId      Int            @map("user_id")
  user        VecindarioUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  communityId Int            @map("community_id")
  community   Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  code        String         @unique @map("code") @db.VarChar(24)
  expiresAt   DateTime       @map("expires_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  @@index([communityId])
  @@index([userId])
  @@map("pool_access_passes")
}

/// Registro mínimo de validaciones (extensible a historial / analítica).
model PoolAccessValidationLog {
  id              Int            @id @default(autoincrement())
  communityId     Int            @map("community_id")
  community       Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  residentUserId  Int            @map("resident_user_id")
  resident        VecindarioUser @relation("PoolValidationResident", fields: [residentUserId], references: [id], onDelete: Cascade)
  validatorUserId Int            @map("validator_user_id")
  validator       VecindarioUser @relation("PoolValidator", fields: [validatorUserId], references: [id], onDelete: Cascade)
  outcome         String         @map("outcome") @db.VarChar(32)
  createdAt       DateTime       @default(now()) @map("created_at")

  @@index([communityId, createdAt])
  @@map("pool_access_validation_logs")
}

/// Personas dentro de la piscina (entrada registrada por socorrista; releasedAt = salida).
model PoolPresenceSession {
  id              Int            @id @default(autoincrement())
  communityId     Int            @map("community_id")
  community       Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  residentUserId  Int            @map("resident_user_id")
  resident        VecindarioUser @relation("PoolPresenceResident", fields: [residentUserId], references: [id], onDelete: Cascade)
  passCode        String         @map("pass_code") @db.VarChar(24)
  peopleCount     Int            @map("people_count")
  validatorUserId Int            @map("validator_user_id")
  validator       VecindarioUser @relation("PoolPresenceValidator", fields: [validatorUserId], references: [id], onDelete: Cascade)
  /// staff = socorrista; self = vecino (enlace/QR fijo en puerta)
  admissionSource String         @default("staff") @map("admission_source") @db.VarChar(16)
  admittedAt      DateTime       @default(now()) @map("admitted_at")
  releasedAt      DateTime?      @map("released_at")

  @@index([communityId, releasedAt])
  @@index([residentUserId, communityId, releasedAt])
  @@map("pool_presence_sessions")
}

/// Registro de entrada/salida al gimnasio (control de acceso); una fila por pulsación.
model CommunityGymAccessLog {
  id               Int             @id @default(autoincrement())
  communityId      Int             @map("community_id")
  community        Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  vecindarioUserId Int?            @map("vecindario_user_id")
  user             VecindarioUser? @relation(fields: [vecindarioUserId], references: [id], onDelete: SetNull)
  /// entrada | salida
  tipo             String          @map("tipo") @db.VarChar(16)
  actorEmail       String?         @map("actor_email") @db.VarChar(255)
  actorPiso        String?         @map("actor_piso") @db.VarChar(64)
  actorPortal      String?         @map("actor_portal") @db.VarChar(64)
  createdAt        DateTime        @default(now()) @map("created_at")

  @@index([vecindarioUserId, communityId, createdAt(sort: Desc)], map: "cgym_user_comm_created_idx")
  @@index([communityId, createdAt(sort: Desc)], map: "cgym_comm_created_idx")
  @@map("community_gym_access_logs")
}

/// Reservas de espacios (pádel, salón, franjas mañana/tarde, etc.): día + minutos desde medianoche + metadatos UI.
model CommunityBooking {
  id               Int             @id @default(autoincrement())
  communityId      Int             @map("community_id")
  community        Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  facilityId       String          @map("facility_id") @db.VarChar(120)
  facilityName     String?         @map("facility_name") @db.VarChar(255)
  /// Día natural de la reserva (calendario local de la comunidad).
  bookingDate      DateTime        @map("booking_date") @db.Date
  /// Minutos desde 00:00 del mismo día (0–1440; mismo día que bookingDate).
  startMinute      Int             @map("start_minute")
  endMinute        Int             @map("end_minute")
  /// Identificador estable en cliente (ej. morning, padel-600-660).
  slotKey          String?         @map("slot_key") @db.VarChar(128)
  /// Texto mostrado (ej. 10:00 – 11:00).
  slotLabel        String?         @map("slot_label") @db.VarChar(255)
  vecindarioUserId Int?            @map("vecindario_user_id")
  user             VecindarioUser? @relation(fields: [vecindarioUserId], references: [id], onDelete: SetNull)
  /// Conserje / gestión que creó la reserva para un vecino (null si reservó el propio vecino).
  bookedByUserId   Int?            @map("booked_by_user_id")
  bookedBy         VecindarioUser? @relation("BookingBookedBy", fields: [bookedByUserId], references: [id], onDelete: SetNull)
  /// Nombre del conserje/gestor en el momento del alta (histórico si cambia el perfil).
  bookedByName     String?         @map("booked_by_name") @db.VarChar(255)
  actorEmail       String?         @map("actor_email") @db.VarChar(255)
  actorPiso        String?         @map("actor_piso") @db.VarChar(64)
  actorPortal      String?         @map("actor_portal") @db.VarChar(64)
  status           String          @default("confirmed") @db.VarChar(32)
  createdAt        DateTime        @default(now()) @map("created_at")

  @@index([bookedByUserId], map: "cb_booked_by_user_idx")
  @@unique([communityId, facilityId, bookingDate, startMinute], map: "cb_comm_facility_date_start")
  @@index([communityId, bookingDate], map: "cb_comm_date_idx")
  @@map("community_bookings")
}

/// Incidencias en zonas comunes: alta como pendiente; personal de gestión / conserje marca resuelta.
model CommunityIncident {
  id               Int             @id @default(autoincrement())
  communityId      Int             @map("community_id")
  community        Community       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  reporterUserId   Int             @map("reporter_user_id")
  reporter         VecindarioUser  @relation("IncidentReporter", fields: [reporterUserId], references: [id], onDelete: Restrict)
  categoryId       String          @map("category_id") @db.VarChar(64)
  categoryLabel    String          @map("category_label") @db.VarChar(128)
  description      String          @db.Text
  locationText     String          @map("location_text") @db.VarChar(512)
  portalLabel      String?         @map("portal_label") @db.VarChar(128)
  urgency          String          @default("medium") @db.VarChar(16)
  /// pendiente | resuelta
  status           String          @default("pendiente") @db.VarChar(32)
  resolvedAt       DateTime?       @map("resolved_at")
  resolvedByUserId Int?            @map("resolved_by_user_id")
  resolvedBy       VecindarioUser? @relation("IncidentResolver", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  /// Nombre de quien marcó resuelta (histórico).
  resolvedByName   String?         @map("resolved_by_name") @db.VarChar(255)
  photoMime        String?         @map("photo_mime") @db.VarChar(64)
  photoBase64      String?         @map("photo_base64") @db.LongText
  createdAt        DateTime        @default(now()) @map("created_at")
  /// Si true, vecinos no pueden añadir comentarios (solo gestión). Lo activa el conserje de la comunidad.
  commentsLocked   Boolean         @default(false) @map("comments_locked")

  comments CommunityIncidentComment[]

  @@index([communityId, status, createdAt(sort: Desc)], map: "ci_comm_status_created_idx")
  @@index([reporterUserId], map: "ci_reporter_idx")
  @@map("community_incidents")
}

/// Comentarios de vecinos y personal en una incidencia (no sustituyen al estado gestionado por portería/admin).
model CommunityIncidentComment {
  id           Int               @id @default(autoincrement())
  incidentId   Int               @map("incident_id")
  incident     CommunityIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  authorUserId Int               @map("author_user_id")
  author       VecindarioUser    @relation("IncidentCommentAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  body         String            @db.Text
  createdAt    DateTime          @default(now()) @map("created_at")

  @@index([incidentId, createdAt(sort: Desc)], map: "cic_incident_created_idx")
  @@map("community_incident_comments")
}

/// Solicitudes de servicio (presupuesto manual por super admin; no marketplace entre vecinos).
model CommunityServiceRequest {
  id               Int            @id @default(autoincrement())
  communityId      Int            @map("community_id")
  community        Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  requesterUserId  Int            @map("requester_user_id")
  requester        VecindarioUser @relation("ServiceRequestRequester", fields: [requesterUserId], references: [id], onDelete: Restrict)
  categoryId       String         @map("category_id") @db.VarChar(64)
  categoryLabel    String         @map("category_label") @db.VarChar(128)
  /// Ej. cleaning_general, plumber_leak_repair, renovation_kitchen… según categoryId.
  serviceSubtype   String?        @map("service_subtype") @db.VarChar(64)
  /// Solo relevante si categoryId = renovation (vecino marca si hace falta visita).
  needsTechnicalVisit Boolean     @default(false) @map("needs_technical_visit")
  description      String         @db.Text
  preferredDate    DateTime?      @map("preferred_date") @db.Date
  /// JSON: [{ "mime": "image/jpeg", "base64": "..." }, …] — misma idea que incidencias.
  photosJson       Json           @default("[]") @map("photos_json")
  /// pending_review | price_sent | accepted | rejected | in_progress | completed
  status           String         @default("pending_review") @db.VarChar(32)
  /// Estimación mínima (o única si priceAmountMax es null).
  priceAmount      Decimal?       @map("price_amount") @db.Decimal(12, 2)
  /// Estimación máxima opcional (rango orientativo para el vecino).
  priceAmountMax   Decimal?       @map("price_amount_max") @db.Decimal(12, 2)
  priceNote        String?        @map("price_note") @db.Text
  priceSentAt      DateTime?      @map("price_sent_at")
  acceptedAt       DateTime?      @map("accepted_at")
  rejectedAt       DateTime?      @map("rejected_at")
  providerName     String?        @map("provider_name") @db.VarChar(255)
  completedAt      DateTime?      @map("completed_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  messages CommunityServiceRequestMessage[]

  @@index([communityId, status, createdAt(sort: Desc)], map: "csr_comm_status_created_idx")
  @@index([requesterUserId], map: "csr_requester_idx")
  @@map("community_service_requests")
}

/// Mensajes vecino ↔ super admin durante el ciclo de la solicitud (hasta completed).
model CommunityServiceRequestMessage {
  id               Int                     @id @default(autoincrement())
  serviceRequestId Int                     @map("service_request_id")
  serviceRequest   CommunityServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  authorUserId     Int                     @map("author_user_id")
  author           VecindarioUser          @relation("ServiceRequestMessageAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  body             String                  @db.Text
  createdAt        DateTime                @default(now()) @map("created_at")

  @@index([serviceRequestId, createdAt(sort: Asc)], map: "csrm_req_created_idx")
  @@map("community_service_request_messages")
}

/// Notificări în aplicația Vecindario (servicii, mesaje, etc.) — livrare UI prin polling / viitor push.
model VecindarioNotification {
  id               Int            @id @default(autoincrement())
  recipientUserId  Int            @map("recipient_user_id")
  recipient        VecindarioUser @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  type             String         @db.VarChar(40)
  title            String         @db.VarChar(255)
  body             String         @db.Text
  readAt           DateTime?      @map("read_at")
  serviceRequestId Int?           @map("service_request_id")
  /// Paquetería: enlace al paquete (tipo `paqueteria_new`).
  parcelId         Int?           @map("parcel_id")
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([recipientUserId, createdAt(sort: Desc)], map: "vn_recipient_created_idx")
  @@index([recipientUserId, readAt], map: "vn_recipient_read_idx")
  @@map("vecindario_notifications")
}

/// Token Expo Push (app móvil) para notificaciones fuera de la app.
model VecindarioExpoPushToken {
  id        Int            @id @default(autoincrement())
  userId    Int            @map("user_id")
  user      VecindarioUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String         @db.VarChar(512)
  updatedAt DateTime       @updatedAt @map("updated_at")

  @@unique([userId, token], map: "vept_user_token_uidx")
  @@index([userId], map: "vept_user_idx")
  @@map("vecindario_expo_push_tokens")
}

/// Suscripción Web Push (PWA).
model VecindarioWebPushSubscription {
  id           Int            @id @default(autoincrement())
  userId       Int            @map("user_id")
  user         VecindarioUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpointKey  String         @unique @map("endpoint_key") @db.VarChar(64)
  endpoint     String         @db.Text
  p256dh       String         @db.Text @map("p256dh")
  auth         String         @db.Text
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  @@index([userId], map: "vwps_user_idx")
  @@map("vecindario_web_push_subscriptions")
}

/// Solicitud de oferta comercial (sustituye el registro libre de vecino sin flujo de comunidad).
model VecindarioQuoteRequest {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  contactName  String  @map("contact_name") @db.VarChar(255)
  contactEmail String  @map("contact_email") @db.VarChar(255)
  contactPhone String? @map("contact_phone") @db.VarChar(64)

  communityName    String  @map("community_name") @db.VarChar(255)
  communityAddress String? @map("community_address") @db.VarChar(512)
  /// Aprox. viviendas / puertas (texto libre).
  dwellingApprox String? @map("dwelling_approx") @db.VarChar(64)
  message        String? @db.Text

  wantServices   Boolean @default(true) @map("want_services")
  wantIncidents  Boolean @default(true) @map("want_incidents")
  wantBookings   Boolean @default(true) @map("want_bookings")
  wantPoolAccess Boolean @default(false) @map("want_pool_access")

  /// new | reviewed | contacted | closed
  status String @default("new") @db.VarChar(32)

  @@index([createdAt], map: "vqr_created_idx")
  @@map("vecindario_quote_requests")
}
