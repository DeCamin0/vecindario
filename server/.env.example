# Copiază la server/.env sau folosește vecindario-app/.env (încărcat automat).
# Migrări Prisma: DATABASE_URL trebuie în vecindario-app/.env (rădăcina proiectului). Din server: npm run db:migrate
# API din acest folder: npm run dev   sau   npm run server:dev
# DATABASE_URL și JWT_SECRET sunt obligatorii pentru API.

DATABASE_URL="mysql://user:password@127.0.0.1:3306/vecindario_db"
JWT_SECRET="minim-32-caractere-aleatorii-schimba-in-productie"
JWT_EXPIRES_IN=7d
PORT=4001

# Origini permise pentru CORS (separate prin virgulă). Dev: frontend Vite.
CORS_ORIGIN=http://localhost:5175,http://localhost:5173

# Doar pentru: npm run seed (din folder server)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=schimba-parola
SUPER_ADMIN_NAME=Super Admin

# --- Correo (alta comunidad: invita presidente / administrador) ---
# Sin SMTP: se crean cuentas igual; la API devuelve contraseñas provisionales en onboarding.devPasswords (solo respuesta al crear).
# URL pública de la app (enlaces en el correo). En producción debe ser https://... para que el logo se vea en Gmail.
APP_PUBLIC_URL=http://localhost:5175
# Logo en correos: si no está definido, con APP_PUBLIC_URL en https se usa APP_PUBLIC_URL + EMAIL_LOGO_PATH (por defecto Vencindario_logo.png en public/).
# Gmail no muestra bien data-URI; en producción usa https o fija EMAIL_LOGO_URL.
# EMAIL_LOGO_URL=https://vecindario.tudominio.es/Vencindario_logo.png
# EMAIL_LOGO_PATH=Vencindario_logo.png
# Solo dev / clientes que soporten data-URI en img: EMAIL_LOGO_DATA_URI=true
#
# Ejemplo DeCamino / serviciodecorreo.es (SMTP SSL puerto 465):
# SMTP_HOST=smtp.serviciodecorreo.es
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=vecindario@decamino.es
# SMTP_PASS=tu_contraseña_buzón
# SMTP_FROM=vecindario@decamino.es
#
# IMAP/POP (solo para clientes tipo Outlook; Vecindario usa solo SMTP de salida):
# imap.serviciodecorreo.es:993 SSL | pop.serviciodecorreo.es:995 SSL
#
# Web Push (PWA): aceleași variabile pot fi în vecindario-app/.env (rădăcină), încărcate de API.
# npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:contact@domeniu.ro
