{
  "name": "vecindario-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "server:dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "postinstall": "prisma generate --schema=../prisma/schema.prisma && node ../scripts/sync-prisma-to-server.mjs",
    "predev": "prisma generate --schema=../prisma/schema.prisma",
    "db:generate": "prisma generate --schema=../prisma/schema.prisma",
    "db:sync": "node ../scripts/sync-prisma-to-server.mjs",
    "db:migrate": "cd .. && prisma migrate deploy",
    "db:migrate:dev": "cd .. && prisma migrate dev",
    "seed": "tsx src/seed-super-admin.ts",
    "subscription:expire-once": "tsx src/scripts/run-subscription-expiry-once.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "web-push": "^3.6.7",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.17.10",
    "@types/nodemailer": "^7.0.11",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
